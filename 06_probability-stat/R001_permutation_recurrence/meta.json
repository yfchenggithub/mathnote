  "math": {
    "core_formula": "A_n^m = (n - m + 1) A_n^{m-1}",
    "related_formulas": [
      "A_n^m = n \\cdot A_{n-1}^{m-1}",
      "A_{n+1}^{m+1} = A_n^{m+1} + (m+1)A_n^m"
    ],
    "variables": "n, m",
    "conditions": "n, m \\in \\mathbb{N}^+, 2 \\le m \\le n",
    "conclusions": "排列数可以按取出个数 m 相邻递推；在证明 A_{n+1}^{m+1}=A_n^{m+1}+(m+1)A_n^m 时通常需 1\\le m\\le n-1。"
  },
  "content": {
    "statement": "设正整数 n,m 满足 2 \\le m \\le n，则 A_n^m=(n-m+1)A_n^{m-1}。",
    "derivation": [
      "由排列数定义：A_n^m=n(n-1)\\cdots(n-m+1)",
      "而 A_n^{m-1}=n(n-1)\\cdots(n-m+2)，所以 A_n^m=(n-m+1)A_n^{m-1}。"
    ],
    "intuition": "先排好 m-1 个位置后，已经用掉 m-1 个元素，还剩 n-(m-1)=n-m+1 个元素可放入第 m 个位置。",
    "common_tricks": [
      "注意因子是 n-m+1 而非 n-m",
      "下标 n 不变，上标从 m-1 递推到 m",
      "若教材未引入 A_n^0，则按 m≥2 使用本公式",
      "常与另一递推 A_n^m=n\\cdot A_{n-1}^{m-1} 联合使用证明恒等式"
    ]
  },
