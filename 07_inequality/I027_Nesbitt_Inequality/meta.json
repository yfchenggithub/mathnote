  "math": {
    "core_formula": "\\text{若 } ab > 0,\\quad \\frac{a}{b} + \\frac{b}{a} \\geq 2;\\quad \\text{若 } ab < 0,\\quad \\frac{a}{b} + \\frac{b}{a} \\leq -2.",
    "related_formulas": [
