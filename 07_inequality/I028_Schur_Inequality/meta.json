    "conditions": [
      "底数非负：x ≥ -1，即 1+x ≥ 0",
      "指数分界：n ≥ 1 或 n ≤ 0 时用“≥”；0 ≤ n ≤ 1 时用“≤”"
    ],
    "conclusions": [
      "当 n ≥ 1 或 n ≤ 0 时，(1+x)^n ≥ 1+nx",
      "当 0 ≤ n ≤ 1 时，(1+x)^n ≤ 1+nx",
      "等号成立当且仅当 n=0, n=1 或 x=0",
      "对任意实数 x，有 e^x ≥ 1+x，等号成立当且仅当 x=0"
    ]
