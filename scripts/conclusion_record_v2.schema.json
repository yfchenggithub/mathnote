{
  "$defs": {
    "AssetInfo": {
      "additionalProperties": false,
      "description": "静态资源层。",
      "properties": {
        "cover": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "封面资源",
          "title": "Cover"
        },
        "svg": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "SVG 资源路径",
          "title": "Svg"
        },
        "png": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "PNG 资源路径",
          "title": "Png"
        },
        "pdf": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "PDF 资源路径",
          "title": "Pdf"
        },
        "mp4": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "视频资源路径",
          "title": "Mp4"
        },
        "extra": {
          "description": "扩展资源列表",
          "items": {
            "$ref": "#/$defs/ExtraAsset"
          },
          "title": "Extra",
          "type": "array"
        }
      },
      "title": "AssetInfo",
      "type": "object"
    },
    "BulletListBlock": {
      "additionalProperties": false,
      "description": "要点列表块。",
      "properties": {
        "id": {
          "description": "块 ID",
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "bullet_list",
          "default": "bullet_list",
          "description": "块类型：无序列表",
          "title": "Type",
          "type": "string"
        },
        "items": {
          "description": "列表项数组",
          "items": {
            "$ref": "#/$defs/BulletListItem"
          },
          "minItems": 1,
          "title": "Items",
          "type": "array"
        }
      },
      "required": [
        "id",
        "items"
      ],
      "title": "BulletListBlock",
      "type": "object"
    },
    "BulletListItem": {
      "additionalProperties": false,
      "description": "无序列表单项。",
      "properties": {
        "tokens": {
          "description": "列表项内容，支持混排",
          "items": {
            "discriminator": {
              "mapping": {
                "line_break": "#/$defs/LineBreakToken",
                "math_display": "#/$defs/MathDisplayToken",
                "math_inline": "#/$defs/MathInlineToken",
                "ref": "#/$defs/RefToken",
                "text": "#/$defs/TextToken"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/TextToken"
              },
              {
                "$ref": "#/$defs/MathInlineToken"
              },
              {
                "$ref": "#/$defs/MathDisplayToken"
              },
              {
                "$ref": "#/$defs/LineBreakToken"
              },
              {
                "$ref": "#/$defs/RefToken"
              }
            ]
          },
          "minItems": 1,
          "title": "Tokens",
          "type": "array"
        }
      },
      "required": [
        "tokens"
      ],
      "title": "BulletListItem",
      "type": "object"
    },
    "ConclusionItem": {
      "additionalProperties": false,
      "description": "结论项。",
      "properties": {
        "id": {
          "description": "结论项 ID",
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "title": {
          "description": "结论标题",
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "content": {
          "description": "结论内容，支持混排",
          "items": {
            "discriminator": {
              "mapping": {
                "line_break": "#/$defs/LineBreakToken",
                "math_display": "#/$defs/MathDisplayToken",
                "math_inline": "#/$defs/MathInlineToken",
                "ref": "#/$defs/RefToken",
                "text": "#/$defs/TextToken"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/TextToken"
              },
              {
                "$ref": "#/$defs/MathInlineToken"
              },
              {
                "$ref": "#/$defs/MathDisplayToken"
              },
              {
                "$ref": "#/$defs/LineBreakToken"
              },
              {
                "$ref": "#/$defs/RefToken"
              }
            ]
          },
          "minItems": 1,
          "title": "Content",
          "type": "array"
        }
      },
      "required": [
        "id",
        "title",
        "content"
      ],
      "title": "ConclusionItem",
      "type": "object"
    },
    "ConditionItem": {
      "additionalProperties": false,
      "description": "适用条件项。",
      "properties": {
        "id": {
          "description": "条件项 ID",
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "title": {
          "description": "条件标题",
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "content": {
          "description": "条件内容，支持混排",
          "items": {
            "discriminator": {
              "mapping": {
                "line_break": "#/$defs/LineBreakToken",
                "math_display": "#/$defs/MathDisplayToken",
                "math_inline": "#/$defs/MathInlineToken",
                "ref": "#/$defs/RefToken",
                "text": "#/$defs/TextToken"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/TextToken"
              },
              {
                "$ref": "#/$defs/MathInlineToken"
              },
              {
                "$ref": "#/$defs/MathDisplayToken"
              },
              {
                "$ref": "#/$defs/LineBreakToken"
              },
              {
                "$ref": "#/$defs/RefToken"
              }
            ]
          },
          "minItems": 1,
          "title": "Content",
          "type": "array"
        },
        "required": {
          "default": true,
          "description": "是否为必要条件",
          "title": "Required",
          "type": "boolean"
        },
        "scope": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "适用范围说明，如 reciprocal_form_only",
          "title": "Scope"
        }
      },
      "required": [
        "id",
        "title",
        "content"
      ],
      "title": "ConditionItem",
      "type": "object"
    },
    "ContentBodyV2": {
      "additionalProperties": false,
      "description": "content 主体。\n\n这是整个 schema v2 的核心层。",
      "properties": {
        "render_schema_version": {
          "const": 2,
          "default": 2,
          "description": "跨端渲染协议版本，当前固定为 2",
          "title": "Render Schema Version",
          "type": "integer"
        },
        "primary_formula": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "主公式 / 核心命题",
          "title": "Primary Formula"
        },
        "variables": {
          "description": "变量定义列表",
          "items": {
            "$ref": "#/$defs/VariableDef"
          },
          "title": "Variables",
          "type": "array"
        },
        "conditions": {
          "description": "适用条件列表",
          "items": {
            "$ref": "#/$defs/ConditionItem"
          },
          "title": "Conditions",
          "type": "array"
        },
        "conclusions": {
          "description": "主要结论列表",
          "items": {
            "$ref": "#/$defs/ConclusionItem"
          },
          "title": "Conclusions",
          "type": "array"
        },
        "sections": {
          "description": "主展示源：结构化 section 列表",
          "items": {
            "$ref": "#/$defs/ContentSection"
          },
          "title": "Sections",
          "type": "array"
        },
        "plain": {
          "$ref": "#/$defs/PlainContent",
          "description": "纯文本兜底层"
        }
      },
      "title": "ContentBodyV2",
      "type": "object"
    },
    "ContentSection": {
      "additionalProperties": false,
      "description": "详情页中的一个主分区。\n\n说明:\n- key 为稳定业务键，便于前端识别与排序\n- title 为展示标题\n- block_type 为该 section 的主风格提示，便于前端快速选择组件\n- blocks 为实际渲染块数组",
      "properties": {
        "key": {
          "description": "分区稳定键，如 core_formula / statement / explanation / proof / traps",
          "minLength": 1,
          "title": "Key",
          "type": "string"
        },
        "title": {
          "description": "分区展示标题",
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "block_type": {
          "description": "分区主类型提示",
          "enum": [
            "rich_text",
            "math_block",
            "theorem_group",
            "proof_steps",
            "example_group",
            "summary",
            "warning_group"
          ],
          "title": "Block Type",
          "type": "string"
        },
        "blocks": {
          "description": "该 section 下的具体内容块列表",
          "items": {
            "discriminator": {
              "mapping": {
                "bullet_list": "#/$defs/BulletListBlock",
                "divider": "#/$defs/DividerBlock",
                "example": "#/$defs/ExampleBlock",
                "math_block": "#/$defs/MathBlock",
                "paragraph": "#/$defs/ParagraphBlock",
                "proof_steps": "#/$defs/ProofStepsBlock",
                "summary_box": "#/$defs/SummaryBoxBlock",
                "theorem_group": "#/$defs/TheoremGroupBlock",
                "warning": "#/$defs/WarningBlock"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/ParagraphBlock"
              },
              {
                "$ref": "#/$defs/MathBlock"
              },
              {
                "$ref": "#/$defs/DividerBlock"
              },
              {
                "$ref": "#/$defs/BulletListBlock"
              },
              {
                "$ref": "#/$defs/TheoremGroupBlock"
              },
              {
                "$ref": "#/$defs/ProofStepsBlock"
              },
              {
                "$ref": "#/$defs/WarningBlock"
              },
              {
                "$ref": "#/$defs/SummaryBoxBlock"
              },
              {
                "$ref": "#/$defs/ExampleBlock"
              }
            ]
          },
          "minItems": 1,
          "title": "Blocks",
          "type": "array"
        }
      },
      "required": [
        "key",
        "title",
        "block_type",
        "blocks"
      ],
      "title": "ContentSection",
      "type": "object"
    },
    "DividerBlock": {
      "additionalProperties": false,
      "description": "分隔线块。",
      "properties": {
        "id": {
          "description": "块 ID",
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "divider",
          "default": "divider",
          "description": "块类型：分隔线",
          "title": "Type",
          "type": "string"
        }
      },
      "required": [
        "id"
      ],
      "title": "DividerBlock",
      "type": "object"
    },
    "ExamExt": {
      "additionalProperties": false,
      "description": "考试维度扩展信息。",
      "properties": {
        "frequency": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "考试出现频率，可按你自己的尺度定义",
          "title": "Frequency"
        },
        "score": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "相关分值参考",
          "title": "Score"
        }
      },
      "title": "ExamExt",
      "type": "object"
    },
    "ExampleBlock": {
      "additionalProperties": false,
      "description": "例题块。",
      "properties": {
        "id": {
          "description": "块 ID",
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "example",
          "default": "example",
          "description": "块类型：例题",
          "title": "Type",
          "type": "string"
        },
        "title": {
          "description": "例题标题，如：例 1（基础）",
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "problem": {
          "description": "题目部分",
          "items": {
            "discriminator": {
              "mapping": {
                "bullet_list": "#/$defs/StepContentBulletList",
                "math_block": "#/$defs/StepContentMath",
                "paragraph": "#/$defs/StepContentParagraph"
              },
              "propertyName": "type"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/StepContentParagraph"
              },
              {
                "$ref": "#/$defs/StepContentMath"
              },
              {
                "$ref": "#/$defs/StepContentBulletList"
              }
            ]
          },
          "minItems": 1,
          "title": "Problem",
          "type": "array"
        },
        "solution": {
          "description": "解答部分，可包含证明步骤组",
          "items": {
            "anyOf": [
              {
                "discriminator": {
                  "mapping": {
                    "bullet_list": "#/$defs/StepContentBulletList",
                    "math_block": "#/$defs/StepContentMath",
                    "paragraph": "#/$defs/StepContentParagraph"
                  },
                  "propertyName": "type"
                },
                "oneOf": [
                  {
                    "$ref": "#/$defs/StepContentParagraph"
                  },
                  {
                    "$ref": "#/$defs/StepContentMath"
                  },
                  {
                    "$ref": "#/$defs/StepContentBulletList"
                  }
                ]
              },
              {
                "$ref": "#/$defs/ProofStepsBlock"
              }
            ]
          },
          "minItems": 1,
          "title": "Solution",
          "type": "array"
        },
        "answer": {
          "anyOf": [
            {
              "items": {
                "discriminator": {
                  "mapping": {
                    "bullet_list": "#/$defs/StepContentBulletList",
                    "math_block": "#/$defs/StepContentMath",
                    "paragraph": "#/$defs/StepContentParagraph"
                  },
                  "propertyName": "type"
                },
                "oneOf": [
                  {
                    "$ref": "#/$defs/StepContentParagraph"
                  },
                  {
                    "$ref": "#/$defs/StepContentMath"
                  },
                  {
                    "$ref": "#/$defs/StepContentBulletList"
                  }
                ]
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "答案部分，可选",
          "title": "Answer"
        }
      },
      "required": [
        "id",
        "title",
        "problem",
        "solution"
      ],
      "title": "ExampleBlock",
      "type": "object"
    },
    "ExtInfo": {
      "additionalProperties": false,
      "description": "扩展信息层。\n\n说明:\n- 放非核心但常用的扩展字段\n- 避免污染顶层与 content 核心层",
      "properties": {
        "share": {
          "anyOf": [
            {
              "$ref": "#/$defs/ShareExt"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "分享信息"
        },
        "relations": {
          "anyOf": [
            {
              "$ref": "#/$defs/RelationsExt"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "关联关系信息"
        },
        "exam": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExamExt"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "考试维度信息"
        },
        "extra": {
          "additionalProperties": true,
          "description": "其它尚未结构化的扩展数据",
          "title": "Extra",
          "type": "object"
        }
      },
      "title": "ExtInfo",
      "type": "object"
    },
    "ExtraAsset": {
      "additionalProperties": false,
      "description": "扩展资源引用。",
      "properties": {
        "kind": {
          "description": "资源类型，如 geogebra / appendix / image / attachment",
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "url": {
          "description": "资源地址",
          "minLength": 1,
          "title": "Url",
          "type": "string"
        },
        "meta": {
          "additionalProperties": true,
          "description": "资源附加元信息",
          "title": "Meta",
          "type": "object"
        }
      },
      "required": [
        "kind",
        "url"
      ],
      "title": "ExtraAsset",
      "type": "object"
    },
    "IdentityInfo": {
      "additionalProperties": false,
      "description": "身份与稳定定位字段。",
      "properties": {
        "slug": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "稳定 slug，可用于 URL / SEO / 前端路由",
          "title": "Slug"
        },
        "module": {
          "description": "所属模块，如 inequality / function / conic",
          "minLength": 1,
          "title": "Module",
          "type": "string"
        },
        "knowledge_node": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "主知识树节点",
          "title": "Knowledge Node"
        },
        "alt_nodes": {
          "description": "可选的其它知识树节点",
          "items": {
            "type": "string"
          },
          "title": "Alt Nodes",
          "type": "array"
        }
      },
      "required": [
        "module"
      ],
      "title": "IdentityInfo",
      "type": "object"
    },
    "LineBreakToken": {
      "additionalProperties": false,
      "description": "换行 token。",
      "properties": {
        "type": {
          "const": "line_break",
          "default": "line_break",
          "description": "Token 类型：换行",
          "title": "Type",
          "type": "string"
        }
      },
      "title": "LineBreakToken",
      "type": "object"
    },
    "MathBlock": {
      "additionalProperties": false,
      "description": "独立公式块。",
      "properties": {
        "id": {
          "description": "块 ID",
          "minLength": 1,
          "title": "Id",
          "type": "string"
        },
        "type": {
          "const": "math_block",
          "default": "math_block",
          "description": "块类型：独立公式块",
          "title": "Type",
          "type": "string"
        },
        "latex": {
          "description": "独立展示的 LaTeX 公式",
          "minLength": 1,
          "title": "Latex",
          "type": "string"
        },
        "align": {
          "default": "center",
          "description": "公式块对齐方式",
          "enum": [
            "left",
            "center",
            "right"
          ],
          "title": "Align",
          "type": "string"
        }
      },
      "required": [
        "id",
        "latex"
      ],
      "title": "MathBlock",
      "type": "object"
    },
    "MathDisplayToken": {
      "additionalProperties": false,
      "description": "展示型公式 token。通常用于少量特殊内联场景；大段公式更建议用 math_block。",
      "properties": {
        "type": {
          "const": "math_display",
          "default": "math_display",
          "description": "Token 类型：展示型公式",
          "title": "Type",
          "type": "string"
        },
        "latex": {
          "description": "LaTeX 公式字符串，用于展示公式渲染",
          "minLength": 1,
          "title": "Latex",
          "type": "string"
        }
      },
      "required": [
        "latex"
      ],
      "title": "MathDisplayToken",
      "type": "object"
    },
    "MathInlineToken": {
      "additionalProperties": false,
      "description": "行内公式 token。",
      "properties": {
        "type": {
          "const": "math_inline",
          "default": "math_inline",
          "description": "Token 类型：行内公式",
          "title": "Type",
          "type": "string"
        },
        "latex": {
          "description": "LaTeX 公式字符串，用于行内渲染",
          "minLength": 1,
          "title": "Latex",
          "type": "string"
        }
      },
      "required": [
        "latex"
      ],
      "title": "MathInlineToken",
      "type": "object"
    },
    "MetaInfo": {
      "additionalProperties": false,
      "description": "业务元数据层。",
      "properties": {
        "title": {
          "description": "内容标题",
          "minLength": 1,
          "title": "Title",
          "type": "string"
        },
        "aliases": {
          "description": "别名列表",
          "items": {
            "type": "string"
          },
          "title": "Aliases",
          "type": "array"
        },
        "difficulty": {
          "anyOf": [
            {
              "maximum": 10,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "难度等级，建议 0~10",
          "title": "Difficulty"
        },
        "category": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "一级分类",
          "title": "Category"
        },
        "tags": {
          "description": "标签列表",
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "简短摘要，用于卡片/SEO/推荐",
